{
  "name": "gdocs-chords-grid-crafter",
  "version": "1.3.0",
  "description": "Create chords grids in Google Docs",
  "main": "build/src/main.js",
  "types": "build/src/main.d.ts",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "gts lint",
    "clean": "gts clean",
    "build": "tsc && cp appsscript.json build/ && cp src/sidebar.html build/src/",
    "build:watch": "tsc --watch",
    "push": "clasp push --watch",
    "fix": "gts fix",
    "docs:serve": "cd docs && bundle exec jekyll serve --livereload"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the8tre/gdocs-chords-grid-crafter.git"
  },
  "author": "ludovic.engrand@gmail.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/the8tre/gdocs-chords-grid-crafter/issues"
  },
  "homepage": "https://github.com/the8tre/gdocs-chords-grid-crafter#readme",
  "dependencies": {
    "@types/google-apps-script": "^2.0.8"
  },
  "devDependencies": {
    "@google/clasp": "^3.0.0",
    "@types/node": "^25.0.0",
    "gts": "^7.0.0",
    "typescript": "^6.0.0"
  }
}
